{
  "name": "tacticiq-backend",
  "version": "1.0.0",
  "description": "TacticIQ Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:report": "node scripts/db-status-report-every-5min.js",
    "db:report:watch": "powershell -ExecutionPolicy Bypass -File scripts/show-db-report-every-5min.ps1",
    "db:rating-only": "node scripts/update-all-player-ratings.js --api",
    "db:phased": "node scripts/run-phased-db-complete.js --delay=350",
    "db:colors-only": "node scripts/run-colors-only-fast.js",
    "db:sync-after-03turkey": "node scripts/run-at-03-turkey-then-sync.js",
    "db:sync-and-report": "node scripts/run-db-sync-and-report.js",
    "db:sync-and-report:loop": "node scripts/run-db-sync-and-report.js --loop",
    "matches:next6h": "node scripts/list-matches-next-6h.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.90.0",
    "axios": "^1.6.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12",
    "pg": "^8.17.2",
    "sharp": "^0.33.5",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
