{
  "watch": ["server.js", "routes/", "services/", "config/", "utils/", "middleware/"],
  "ignore": [
    "data",
    "data/**",
    "**/data/**",
    "backups",
    "scripts",
    "node_modules",
    "**/*.json",
    "**/*.log",
    "**/*.txt",
    ".env",
    "**/api-usage*.json",
    "**/db-status*"
  ],
  "ext": "js",
  "delay": "3000"
}
